generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum OrderStatus {
  Pending
  Processing
  Shipped
  Delivered
  Cancelled
}

enum UserRole {
  USER
  ADMIN
  SELLER
}

enum UserStatus {
  active
  banned
}

enum InteractionType {
  CATEGORY_VIEW
  MEDICINE_VIEW
  MEDICINE_SEARCH
}

// ─────────────────────────────────────────
// AUTH MODELS
// ─────────────────────────────────────────

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  role          UserRole   @default(USER)
  status        UserStatus @default(active)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  sessions  Session[]
  accounts  Account[]
  medicines Medicines[]
  orders    Orders[]
  reviews   Reviews[]
  cards     Card[]

  // AI Relations
  searchLogs SearchLog[]
  viewLogs   ViewLog[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────

model Categories {
  id            String   @id @default(uuid())
  categorieName String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  medicines Medicines[]
}

model Medicines {
  id           String  @id @default(uuid())
  medicineName String
  price        Int
  image        String?
  stock        Int     @default(0)
  detels       String
  manufacturer String

  // AI Fields
  uses        String? // কি কাজে লাগে
  sideEffects String? // পার্শ্বপ্রতিক্রিয়া
  isVectored  Boolean   @default(false) // Pinecone এ store হয়েছে কিনা
  vectoredAt  DateTime? // কখন vector হয়েছে

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sellerId    String
  seller      User       @relation(fields: [sellerId], references: [id])
  categorieId String
  categorie   Categories @relation(fields: [categorieId], references: [id])

  orderItems OrderItem[]
  reviews    Reviews[]
  cards      Card[]
  viewLogs   ViewLog[]
  embedding  MedicineEmbedding?
}

model Orders {
  id              String      @id @default(uuid())
  shippingAddress String
  totalAmount     Int
  status          OrderStatus @default(Pending)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customerId String
  customer   User        @relation(fields: [customerId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Int // order করার সময়ের price save করো

  orderId   String
  order     Orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Medicines @relation(fields: [productId], references: [id])
}

model Reviews {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   User      @relation(fields: [customerId], references: [id])
  productId  String
  product    Medicines @relation(fields: [productId], references: [id])
}

model Card {
  id       String @id @default(uuid())
  quantity Int

  customerId String
  customer   User      @relation(fields: [customerId], references: [id])
  productId  String
  product    Medicines @relation(fields: [productId], references: [id])

  // একজন user একটা product একবারই cart এ রাখতে পারবে
  @@unique([customerId, productId])
}

// ─────────────────────────────────────────
// AI TRACKING MODELS
// ─────────────────────────────────────────

// User কি search করেছে track করে
model SearchLog {
  id        String   @id @default(uuid())
  query     String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// User কোন medicine দেখেছে track করে
model ViewLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicines @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([medicineId])
}

model MedicineEmbedding {
  id         String                       @id @default(uuid())
  medicineId String                       @unique
  medicine   Medicines                    @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  embedding  Unsupported("vector(1024)")? // 768 → 1024
  content    String
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
}
